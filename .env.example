# Telegram bot token from @BotFather. Keep empty in git examples.
BOT_TOKEN=

# Public HTTPS URL of this app, e.g. https://your-domain.ru or https://abc.ngrok-free.app
WEB_APP_URL=https://example.com

# Telegram numeric IDs that can create events, players and settle results
ADMIN_IDS=

# Local dev only: allows browser login without Telegram initData as Dev User
ALLOW_DEV_LOGIN=true

# Local/dev only: seed demo data on startup when DB is empty. Keep false in production.
SEED_DEMO=false

# Run aiogram polling inside the FastAPI process for local/dev
ENABLE_POLLING=true

# SQLite path
DB_PATH=./data/dygyn.sqlite3

# Frontend static directory. Default uses Vue build; set web for legacy rollback.
FRONTEND_DIR=./web-vue/dist

# SQLite backup script defaults
BACKUP_DIR=./backups
BACKUP_KEEP=24

# Telegram initData max age. Set 0 to disable age check, but production should keep it finite.
AUTH_MAX_AGE_SECONDS=86400
